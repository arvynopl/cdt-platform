# Copy to .env for local development. Never commit .env.
# This file is auto-loaded by config.py (python-dotenv); real environment
# variables take precedence over values here.
# Unset CDT_DATABASE_URL → falls back to local SQLite (backend/cdt_bias.db).
CDT_DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
# Optional: Sentry error monitoring (project DSN from sentry.io).
SENTRY_DSN=
CDT_BCRYPT_ROUNDS=12
CDT_DEBUG=
